{
  "compilerOptions": {
    "module": "nodenext",
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "paths": {
      "@lib": ["./src/"],
      "@lib/*": ["./src/*"],
      "@core": ["./src/core"],
      "@core/*": ["./src/core/*"]
    }
  },
  "include": ["./src/"]
}
