# @your_bot
MAX_BOT_TOKEN=XXXXX

# Публичный HTTPS URL этого webhook endpoint.
# Для локальной проверки обычно нужен туннель, например ngrok/cloudflared.
MAX_WEBHOOK_URL=https://example.com/max-webhook

# Локальный порт HTTP-сервера.
MAX_WEBHOOK_PORT=3000

# Path webhook endpoint внутри локального сервера.
MAX_WEBHOOK_PATH=/max-webhook

# Секрет для заголовка X-Max-Bot-Api-Secret.
# По схеме: 5-256 символов, A-Z, a-z, 0-9 и дефис.
MAX_WEBHOOK_SECRET=change-me-12345

# Типы updates через запятую. Пустое значение означает подписку на все доступные типы.
MAX_WEBHOOK_UPDATE_TYPES=message_created,message_callback,bot_started

# При запуске yarn server сразу получить список подписок и создать/обновить подписку из .env.
MAX_WEBHOOK_AUTO_SUBSCRIBE=true
